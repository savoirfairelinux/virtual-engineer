{
  "name": "virtual-engineer-agent-worker",
  "version": "1.0.0",
  "description": "Agent worker using GitHub Copilot SDK",
  "main": "dist/index.js",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "esbuild src/index.ts src/validate-copilot-connection.ts --platform=node --format=cjs --bundle --external:@github/copilot-sdk --external:@anthropic-ai/claude-agent-sdk --outdir=dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.0",
    "@github/copilot-sdk": "^0.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "@hono/node-server": "2.0.11"
    }
  }
}
