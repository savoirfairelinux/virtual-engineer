# Virtual Engineer — environment configuration
# Copy to .env and fill in your values.
#
# All provider configuration is managed from the admin UI 
# at http://127.0.0.1:3100/admin after startup.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
DATABASE_PATH=./data/virtual-engineer.db
ADMIN_API_ENABLED=true
ADMIN_API_HOST=0.0.0.0
ADMIN_API_PORT=3100
# ADMIN_AUTH_SECRET=your-hmac-secret    # Recommended for network-exposed instances

# ─── Workflow ─────────────────────────────────────────────────────────────────
# Polling interval, max agent cycles, and max retry attempts are now managed from
# the admin UI (Configuration → System Settings) and persisted in the database.
AGENT_TIMEOUT_MS=1800000

# ─── Agent sandbox ───────────────────────────────────────────────────────────
AGENT_CONTAINER_IMAGE=virtual-engineer-workspace:latest
WORKSPACE_BASE_DIR=/tmp/virtual-engineer/workspaces

# ─── OpenShell OIDC ──────────────────────────────────────────────────────────
# OpenShell always owns sandbox execution. Its Docker compute driver is the
# default; set kubernetes only to exercise the experimental k3s/Helm path.
OPENSHELL_COMPUTE_DRIVER=docker
# Leave issuer and secret empty to let scripts/start.sh deploy a managed local
# Keycloak. To use an external provider, set both values together and keep the
# filled .env local and uncommitted.
OPENSHELL_OIDC_ISSUER=
OPENSHELL_OIDC_CLIENT_ID=openshell-ci
OPENSHELL_OIDC_CLIENT_SECRET=
OPENSHELL_OIDC_AUDIENCE=openshell-cli
