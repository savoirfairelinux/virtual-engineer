FROM node:24-bookworm-slim

# Suppress interactive prompts from apt-get and npm
ENV DEBIAN_FRONTEND=noninteractive
ENV NPM_CONFIG_UPDATE_NOTIFIER=false

# Install required tools: git, SSH client, GitHub CLI, curl, jq.
# iproute2 provides the `ip` binary the OpenShell supervisor needs to create the
# sandbox network namespace (proxy-mode isolation); without it the sandbox agent
# container crash-loops with "trusted ip helper not found".
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    openssh-client \
    curl \
    ca-certificates \
    jq \
    iproute2 \
  && rm -rf /var/lib/apt/lists/*
RUN groupadd --system sandbox \
  && useradd --system --gid sandbox --create-home \
    --home-dir /sandbox --shell /bin/bash sandbox
# Default SSH config — accepts unknown host keys as a fallback for ephemeral
# sandboxes. When sshKnownHostsPath is configured on the Gerrit integration,
# host-side git (HostGitExecutor / buildGitEnv) overrides GIT_SSH_COMMAND with
# strict checking for the push that runs in the orchestrator.
RUN mkdir -p ~/.ssh && echo "Host gerrit\n  StrictHostKeyChecking=no\n  UserKnownHostsFile=/dev/null" > ~/.ssh/config

# Install GitHub CLI
# Default GIT_SSH_COMMAND — overridden at runtime by dockerVolume.ts when
# sshKeyPath (and optionally sshKnownHostsPath) are configured.
ENV GIT_SSH_COMMAND="ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null"
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
    | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
  && chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg \
  && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
    > /etc/apt/sources.list.d/github-cli.list \
  && apt-get update && apt-get install -y --no-install-recommends gh \
  && rm -rf /var/lib/apt/lists/*

# Keep the runtime under /app, which OpenShell's default filesystem policy
# permits as read-only executable content.
COPY agent-worker/ /app/agent-worker/
RUN npm --prefix /app/agent-worker ci --no-fund \
  && npm --prefix /app/agent-worker run build \
  && npm --prefix /app/agent-worker prune --omit=dev --no-fund

# Set working directory. The OpenShell sandbox overrides the working directory
# to `/sandbox` (its writable dir under the default policy); this WORKDIR is only
# a fallback for non-OpenShell invocations.
WORKDIR /workspace

# Default shell
CMD ["/bin/bash"]
