{
  "realm": "openshell",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      { "name": "openshell-admin" },
      { "name": "openshell-user" }
    ]
  },
  "clients": [
    {
      "clientId": "openshell-cli",
      "name": "OpenShell API",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    },
    {
      "clientId": "openshell-ci",
      "name": "Virtual Engineer OpenShell client",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${OPENSHELL_OIDC_CLIENT_SECRET}",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "protocolMappers": [
        {
          "name": "openshell-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.client.audience": "openshell-cli",
            "access.token.claim": "true"
          }
        },
        {
          "name": "openshell-realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-openshell-ci",
      "enabled": true,
      "serviceAccountClientId": "openshell-ci",
      "realmRoles": ["openshell-admin", "openshell-user"]
    }
  ]
}
